# API Keys for External Services
GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key_here
NEMO_API_KEY=your_nemo_api_key_here
CUSTOM_SERVICE_API_KEY=your_custom_service_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Yandex SpeechKit Configuration
YANDEX_SPEECHKIT_API_KEY=your_yandex_speechkit_api_key_here
YANDEX_FOLDER_ID=your_yandex_folder_id_here
YANDEX_IAM_TOKEN=your_yandex_iam_token_here

# Flask Settings (if using web interface)
FLASK_SECRET_KEY=generate_a_secure_random_key_here
FLASK_ENV=development

# Other Settings
MAX_FILE_SIZE_MB=500
